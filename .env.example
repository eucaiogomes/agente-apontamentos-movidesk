# Copie para skills/relatorios-movidesk/.env e preencha (NUNCA versione o .env real).
# Os scripts leem esse arquivo automaticamente a partir da raiz da skill.
# Alternativa: exportar as variaveis no ambiente (tem precedencia sobre o .env).

# Token da API pública do Movidesk (obrigatório).
MOVIDESK_TOKEN=coloque-seu-token-aqui

# Pasta de saída dos relatórios (opcional).
# Padrão: ~/Downloads/Relatorios Movidesk
# RELATORIOS_MOVIDESK_DIR=C:\caminho\para\Relatorios Movidesk

# Extrator Obsidian (aba Extrator do painel) — opcional.
# EXTRATOR_OBSIDIAN_DIR=C:\Users\voce\Downloads\...\movidesk-obsidian
# MOVIDESK_SUBDOMAIN=lectortec

# --- Envio ao WhatsApp (Evolution API) — opcional ---
# EVOLUTION_SSH=root@SEU_VPS
# EVOLUTION_BASE=http://127.0.0.1:36721
# EVOLUTION_KEY=coloque-sua-apikey-aqui
# EVOLUTION_INSTANCE=Whatsapp lector
# EVOLUTION_GROUP=1203630XXXXXXXXXXXX@g.us
# EVOLUTION_CONTAINER=evolution-api-xxxx-api-1
# ENVIAR_WHATSAPP=0        # 1 liga o envio ao final de cada missao
# (mapa nome->numero em skills/relatorios-movidesk/whatsapp_agentes.json, fora do repo)
