# Copie para skills/relatorios-movidesk/.env e preencha (NUNCA versione o .env real).
# Os scripts leem esse arquivo automaticamente a partir da raiz da skill.
# Alternativa: exportar as variaveis no ambiente (tem precedencia sobre o .env).

# Token da API pública do Movidesk (obrigatório).
MOVIDESK_TOKEN=coloque-seu-token-aqui

# Pasta de saída dos relatórios (opcional).
# Padrão: ~/Downloads/Relatorios Movidesk
# RELATORIOS_MOVIDESK_DIR=C:\caminho\para\Relatorios Movidesk
